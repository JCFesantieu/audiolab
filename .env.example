# GEMINI_API_KEY: Clé requise pour interroger l'API Google Gemini.
# Obtenez une clé sur https://aistudio.google.com/
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: URL racine de l'application (locale ou de production).
# Utilisée pour les liens d'API et les rappels OAuth.
APP_URL="http://localhost:3000"
